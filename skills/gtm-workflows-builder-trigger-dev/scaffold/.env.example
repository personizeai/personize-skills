# ═══════════════════════════════════════════
# Personize SDK (required)
# ═══════════════════════════════════════════
PERSONIZE_SECRET_KEY=sk_live_your_key_here

# ═══════════════════════════════════════════
# Trigger.dev (required)
# ═══════════════════════════════════════════
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# ═══════════════════════════════════════════
# Gmail (for email pipelines)
# Option A: Service account (recommended for your own domain)
# Option B: OAuth app credentials
# ═══════════════════════════════════════════
GMAIL_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json
GMAIL_DELEGATED_USER=you@yourdomain.com

# Or OAuth credentials:
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REFRESH_TOKEN=your_refresh_token

# ═══════════════════════════════════════════
# HubSpot (for CRM pipelines)
# Use a private app access token
# ═══════════════════════════════════════════
HUBSPOT_ACCESS_TOKEN=pat-na1-your-token-here

# ═══════════════════════════════════════════
# Salesforce (for CRM pipelines)
# ═══════════════════════════════════════════
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_USERNAME=your_username
SALESFORCE_PASSWORD=your_password
SALESFORCE_SECURITY_TOKEN=your_security_token

# ═══════════════════════════════════════════
# Apollo.io (for enrichment pipelines)
# ═══════════════════════════════════════════
APOLLO_API_KEY=your_apollo_api_key

# ═══════════════════════════════════════════
# Tavily (for web research pipelines)
# ═══════════════════════════════════════════
TAVILY_API_KEY=tvly-your_key_here

# ═══════════════════════════════════════════
# Exa (for semantic/neural web search)
# ═══════════════════════════════════════════
EXA_API_KEY=your_exa_api_key

# ═══════════════════════════════════════════
# Slack (for notifications)
# Use a bot token from your Slack app
# ═══════════════════════════════════════════
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_DEFAULT_CHANNEL=sales-alerts

# ═══════════════════════════════════════════
# Twilio (for SMS/WhatsApp pipelines)
# ═══════════════════════════════════════════
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════
# SendGrid (for transactional email)
# ═══════════════════════════════════════════
SENDGRID_API_KEY=SG.your_key_here
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=Your Name
